# ============================
# LLM Server Router - 環境設定
# ============================

# llama.cpp 二進位檔案路徑
LLAMA_ROCM_PATH=/path/to/llama-server-rocm
LLAMA_VULKAN_PATH=/path/to/llama-server-vulkan
# AMD GPU 環境變數
HSA_OVERRIDE_GFX_VERSION=11.5.0

# 預設 llama-server 監聽埠
LLAMA_SERVER_PORT=8081

# 遠端 API 金鑰 (用於 fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OAuth client settings
# These are read from the repo root .env when not overridden in Settings.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 資料庫路徑
DATABASE_URL=sqlite:///./llm_router.db
